@using RimionshipServer.Models

@inherits LayoutComponentBase

<HeaderComponent />

<AuthorizeView>
	<Authorized>
		
		<div id="TESTING">
			<RadzenChart>
				<RadzenColumnSeries Data=@revenue CategoryProperty="Quarter" ValueProperty="Revenue" />
			</RadzenChart>
			@code {
				class DataItem
				{
					 public string Quarter { get; set; }
					 public double Revenue { get; set; }
				}
				DataItem[] revenue = new DataItem[]
				{
					 new DataItem { Quarter = "Q1", Revenue = 234000 },
					 new DataItem { Quarter = "Q2", Revenue = 284000 },
					 new DataItem { Quarter = "Q3", Revenue = 274000 },
					 new DataItem { Quarter = "Q4", Revenue = 294000 }
				};
			}
		 </div>

	</Authorized>

	<NotAuthorized>
		<div class="alert alert-warning fs-5" role="alert">
			Please login using the button on the top right to access the dashboard.
		</div>
	</NotAuthorized>
</AuthorizeView>
